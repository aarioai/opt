#!/bin/bash
set -euo pipefail

# https://github.com/aarioai/opt
if [ -x "../../aa/lib/aa-posix-lib.sh" ]; then . ../../aa/lib/aa-posix-lib.sh; else . /opt/aa/lib/aa-posix-lib.sh; fi

help(){
  cat <<-EOF
k8s

EOF
}


main(){
  if ! IAmRoot; then
    exec sudo "${BASH_SOURCE[0]}" "$@"
    return 0
  fi

  Usage $# ge 1 "k8s <cmd> [options]"
  local cmd="$1"
  shift
  case "$cmd" in
    *) help ;;
  esac
}

main "$@"